{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Dashboard": {
    "BaseUrl": "http://127.0.0.1:8080",
    "SessionTimeoutMinutes": 480,
    "ComposeProject": "contexthub",
    "DockerEndpoint": "unix:///var/run/docker.sock",
    "DockerSnapshotCacheSeconds": 3,
    "DockerSnapshotTimeoutSeconds": 4,
    "DataProtectionPath": "/var/lib/contexthub-dashboard/keys",
    "Polling": {
      "OverviewSeconds": 10,
      "MetricsSeconds": 3,
      "JobsSeconds": 8,
      "LogsSeconds": 10,
      "PerformanceSeconds": 30
    }
  }
}
