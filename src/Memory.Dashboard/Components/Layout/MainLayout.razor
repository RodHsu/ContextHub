@inherits LayoutComponentBase
@using Memory.Application

<AuthorizeView>
    <Authorized Context="auth">
        <div class="dashboard-shell">
            <aside class="sidebar">
                <div class="sidebar-inner">
                    <div class="brand">
                        <div class="brand-mark">C</div>
                        <div>
                            <div class="brand-title">ContextHub</div>
                            <div class="brand-subtitle">Knowledge Console</div>
                        </div>
                    </div>

                    <div class="sidebar-section-label">維運監控</div>
                    <nav class="sidebar-nav">
                        <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M3 10.5 12 3l9 7.5" />
                                    <path d="M5.25 9.75V21h13.5V9.75" />
                                </svg>
                            </span>
                            <span class="nav-label">總覽</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/monitoring">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 18h16" />
                                    <path d="M6.5 15.5 10 11l3 2.5 4.5-6" />
                                    <circle cx="6.5" cy="15.5" r="1" />
                                    <circle cx="10" cy="11" r="1" />
                                    <circle cx="13" cy="13.5" r="1" />
                                    <circle cx="17.5" cy="7.5" r="1" />
                                </svg>
                            </span>
                            <span class="nav-label">狀態監控</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/runtime">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 6h16" />
                                    <path d="M4 12h16" />
                                    <path d="M4 18h10" />
                                    <path d="M18 16v4" />
                                    <path d="M16 18h4" />
                                </svg>
                            </span>
                            <span class="nav-label">執行參數</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/logs">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M7 4h10" />
                                    <path d="M6 8h12" />
                                    <path d="M6 12h12" />
                                    <path d="M6 16h7" />
                                    <path d="M17.5 17.5 20 20" />
                                    <circle cx="15" cy="15" r="3.25" />
                                </svg>
                            </span>
                            <span class="nav-label">日誌</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/jobs">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="4" y="5" width="16" height="14" rx="2" />
                                    <path d="M8 3v4" />
                                    <path d="M16 3v4" />
                                    <path d="M8 11h8" />
                                </svg>
                            </span>
                            <span class="nav-label">工作佇列</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/performance">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 19h16" />
                                    <path d="m7 15 3-3 2.5 2.5L17 10" />
                                    <path d="M17 10h-3" />
                                    <path d="M17 10v3" />
                                </svg>
                            </span>
                            <span class="nav-label">效能</span>
                        </NavLink>
                    </nav>

                    <div class="sidebar-section-label">知識工作</div>
                    <nav class="sidebar-nav">
                        <NavLink class="nav-item" href="/graph">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="6.5" cy="7" r="2.25" />
                                    <circle cx="17.5" cy="6.5" r="2.25" />
                                    <circle cx="12" cy="17" r="2.5" />
                                    <path d="M8.5 8.1 15.4 7.1" />
                                    <path d="m8 8.8 2.9 6" />
                                    <path d="m16.3 8.5-3 5.9" />
                                </svg>
                            </span>
                            <span class="nav-label">記憶圖譜</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/memories">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M6.5 4.5h9A2.5 2.5 0 0 1 18 7v12l-3-1.8L12 19l-3-1.8L6 19V7a2.5 2.5 0 0 1 2.5-2.5Z" />
                                </svg>
                            </span>
                            <span class="nav-label">記憶資料</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/sources">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M8 8h8" />
                                    <path d="M8 12h8" />
                                    <path d="M8 16h8" />
                                    <path d="M4 8h.01" />
                                    <path d="M4 12h.01" />
                                    <path d="M4 16h.01" />
                                </svg>
                            </span>
                            <span class="nav-label">資料來源</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/governance">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 3 5 6v5c0 4.2 2.8 8 7 10 4.2-2 7-5.8 7-10V6l-7-3Z" />
                                    <path d="m9.5 12 1.5 1.5 3.5-3.5" />
                                </svg>
                            </span>
                            <span class="nav-label">治理檢查</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/evaluation">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 19h16" />
                                    <path d="M7 15V9" />
                                    <path d="M12 15V5" />
                                    <path d="M17 15v-3" />
                                </svg>
                            </span>
                            <span class="nav-label">評估驗證</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/inbox">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 5h16v11H4z" />
                                    <path d="M4 13h4l2 3h4l2-3h4" />
                                </svg>
                            </span>
                            <span class="nav-label">收件匣</span>
                        </NavLink>
                    </nav>

                    <div class="sidebar-section-label">管理設定</div>
                    <nav class="sidebar-nav">
                        <NavLink class="nav-item" href="/preferences">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M12 13a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
                                    <path d="M4 20a8 8 0 0 1 16 0" />
                                </svg>
                            </span>
                            <span class="nav-label">使用者偏好</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/storage">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <ellipse cx="12" cy="6" rx="7" ry="3" />
                                    <path d="M5 6v6c0 1.7 3.1 3 7 3s7-1.3 7-3V6" />
                                    <path d="M5 12v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6" />
                                </svg>
                            </span>
                            <span class="nav-label">資料庫檢視</span>
                        </NavLink>
                        <NavLink class="nav-item" href="/settings">
                            <span class="nav-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="3.25" />
                                    <path d="M19.4 15a1 1 0 0 0 .2 1.1l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1 1 0 0 0-1.1-.2 1 1 0 0 0-.6.9V20a2 2 0 1 1-4 0v-.2a1 1 0 0 0-.6-.9 1 1 0 0 0-1.1.2l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1 1 0 0 0 .2-1.1 1 1 0 0 0-.9-.6H4a2 2 0 1 1 0-4h.2a1 1 0 0 0 .9-.6 1 1 0 0 0-.2-1.1l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1 1 0 0 0 1.1.2 1 1 0 0 0 .6-.9V4a2 2 0 1 1 4 0v.2a1 1 0 0 0 .6.9 1 1 0 0 0 1.1-.2l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1 1 0 0 0-.2 1.1 1 1 0 0 0 .9.6H20a2 2 0 1 1 0 4h-.2a1 1 0 0 0-.9.6Z" />
                                </svg>
                            </span>
                            <span class="nav-label">系統設定</span>
                        </NavLink>
                    </nav>

                    <div class="sidebar-bottom">
                        <div class="sidebar-build">
                            <span class="sidebar-build-label">Dashboard UI</span>
                            <span class="sidebar-build-value">@BuildMetadata.Current.Version</span>
                            <span class="sidebar-build-time"><ClientLocalTime Value="BuildMetadata.Current.TimestampUtc" /></span>
                        </div>
                    </div>
                </div>
            </aside>

            <div class="main-shell">
                <header class="topbar">
                    <div class="topbar-context">
                        <div class="topbar-title">
                            <span class="status-dot"></span>
                            <span>ContextHub 管理主控台</span>
                        </div>
                        <div class="topbar-subtitle">知識、日誌與背景工作的單一操作入口</div>
                    </div>

                    <div class="topbar-actions">
                        <ThemeSwitcher />
                        <span class="topbar-user">@auth.User.Identity?.Name</span>
                        <form method="post" action="/account/logout">
                            <AntiforgeryToken />
                            <button type="submit" class="ghost-button">登出</button>
                        </form>
                    </div>
                </header>

                <main class="content">
                    @Body
                </main>
            </div>
        </div>
    </Authorized>
</AuthorizeView>
